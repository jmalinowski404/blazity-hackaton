# Copy this file to .env.local and fill in values. .env.local is gitignored.

# --- Claude (required for the brand check) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Meta / Facebook + Instagram (required for the "Channels" social connect) ---
# Create an app at https://developers.facebook.com/ → add the "Facebook Login" product.
# Add this OAuth redirect URI in the app:  http://localhost:3000/api/auth/facebook/callback
# In development, add yourself as a Tester/Admin so the scopes work without full App Review.
META_APP_ID=
META_APP_SECRET=
# Optional: override the redirect URI (defaults to <origin>/api/auth/facebook/callback)
# META_REDIRECT_URI=
# Optional: pin a Graph API version (defaults to v21.0)
# META_GRAPH_VERSION=v21.0
